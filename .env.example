# .env.example — riferimento per il formato del .env PER STORE.
#
# Questo file è solo uno SCHEMA. Non metterci mai token veri qui.
# Il vero .env con il token va in ogni cartella store, NON nel plugin.
#
# Path del .env vero (esempio Mac):
#   ~/Desktop/Shopify-Stores/Nimea/.env
#   ~/Desktop/Shopify-Stores/Glowria/.env
#
# Come ottenere il token:
#   1. Apri Shopify Admin dello store.
#   2. Apps → cerca "Theme Access" → installa (se non già installata).
#   3. Crea un nuovo accesso intestato a te, copia il token generato.
#   4. Incolla il token qui sotto nel .env della cartella store giusta.

SHOPIFY_CLI_THEME_TOKEN=shptka_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_FLAG_STORE=your-store-handle.myshopify.com
